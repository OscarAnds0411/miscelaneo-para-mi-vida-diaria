```gitignore
# =========================================================
#                PYTHON (BASE PROFESIONAL)
# =========================================================

# Bytecode compilado (no aporta nada al repositorio)
__pycache__/
*.py[codz]
*$py.class

# Extensiones compiladas (C/Cython)
*.so

# ---------------------------------------------------------
# DISTRIBUCIÓN / BUILD
# ---------------------------------------------------------
# Archivos generados al empaquetar o construir el proyecto
.Python
build/
dist/
develop-eggs/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ---------------------------------------------------------
# PYINSTALLER
# ---------------------------------------------------------
# Archivos temporales al crear ejecutables
*.manifest
*.spec

# ---------------------------------------------------------
# LOGS E INSTALACIÓN
# ---------------------------------------------------------
pip-log.txt
pip-delete-this-directory.txt

# ---------------------------------------------------------
# TESTING / COVERAGE
# ---------------------------------------------------------
# Resultados de pruebas y cobertura (son generados automáticamente)
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py.cover
.hypothesis/
.pytest_cache/
cover/

# ---------------------------------------------------------
# INTERNACIONALIZACIÓN
# ---------------------------------------------------------
*.mo
*.pot

# ---------------------------------------------------------
# FRAMEWORKS
# ---------------------------------------------------------

# Django
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal

# Flask
instance/
.webassets-cache

# Scrapy
.scrapy

# ---------------------------------------------------------
# DOCUMENTACIÓN
# ---------------------------------------------------------
docs/_build/

# ---------------------------------------------------------
# HERRAMIENTAS DE BUILD
# ---------------------------------------------------------
.pybuilder/
target/

# ---------------------------------------------------------
# NOTEBOOKS
# ---------------------------------------------------------
# Checkpoints automáticos de Jupyter
.ipynb_checkpoints

# ---------------------------------------------------------
# IPYTHON
# ---------------------------------------------------------
profile_default/
ipython_config.py

# ---------------------------------------------------------
# ENTORNOS VIRTUALES
# ---------------------------------------------------------
# Nunca se versionan dependencias instaladas
.env
.envrc
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# ---------------------------------------------------------
# MANEJADORES DE DEPENDENCIAS
# ---------------------------------------------------------

# pipenv (lockfile opcional dependiendo del equipo)
#Pipfile.lock

# poetry (recomendado incluirlo en proyectos cerrados)
#poetry.lock
#poetry.toml

# pdm
#pdm.lock
#pdm.toml
.pdm-python
.pdm-build/

# pixi
#pixi.lock
.pixi

# PEP 582
__pypackages__/

# ---------------------------------------------------------
# HERRAMIENTAS DE DESARROLLO
# ---------------------------------------------------------

# Spyder
.spyderproject
.spyproject

# Rope
.ropeproject

# mkdocs
/site

# Tipado estático
.mypy_cache/
.dmypy.json
dmypy.json

.pyre/
.pytype/

# Cython debug
cython_debug/

# Ruff (linter)
.ruff_cache/

# PyPI config local
.pypirc

# ---------------------------------------------------------
# EDITORES / IDEs
# ---------------------------------------------------------

# VSCode
.vscode/

# JetBrains (PyCharm, IntelliJ)
.idea/

# Cursor (editor con IA)
.cursorignore
.cursorindexingignore

# ---------------------------------------------------------
# SISTEMA OPERATIVO
# ---------------------------------------------------------
.DS_Store
Thumbs.db

# =========================================================
#                LATEX (CLAVE PARA TU CASO)
# =========================================================

# Archivos auxiliares generados por compilación
# (NO deben versionarse porque cambian en cada compilación)
*.aux
*.bbl
*.blg
*.brf
*.idx
*.ilg
*.ind
*.lof
*.lot
*.out
*.toc

# Glosarios y acrónimos
*.acn
*.acr
*.alg
*.glg
*.glo
*.gls
*.ist

# latexmk (automatización de compilación)
*.fls
*.fdb_latexmk

# Sincronización con editores (ej. VSCode, TexStudio)
*.synctex.gz

# Presentaciones (beamer)
*.nav
*.snm
*.vrb

# ---------------------------------------------------------
# PDF (DECISIÓN IMPORTANTE)
# ---------------------------------------------------------
# ⚠️ COMENTA o DESCOMENTA según tu flujo:

# Caso 1 (RECOMENDADO en tesis / investigación):
#   -> Sí quieres guardar versiones compiladas
#   -> Mantén los PDFs en el repo
#*.pdf

# Caso 2 (flujo tipo desarrollo):
#   -> Solo versionas .tex
#   -> Ignoras PDFs
# *.pdf


# =========================================================
#                DATOS (AJUSTE FINO IMPORTANTE)
# =========================================================

# ⚠️ EVITAMOS ignorar TODOS los .csv/.xlsx globalmente
# porque pueden ser parte del proyecto

# Temporales de Excel (estos SÍ estorban)
~$*.xlsx

# Datos generados o pesados (ajusta rutas a tu proyecto)
data/*.csv
data/*.xlsx

# Archivos temporales generales
*.tmp


# =========================================================
#                OTROS / PERSONAL
# =========================================================

# Configuraciones locales (no deben subirse)
config.local.*

# Abstra (framework de automatización)
.abstra/

# Marimo
marimo/_static/
marimo/_lsp/
__marimo__/

# Claude configs
.claude